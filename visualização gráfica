    private void jButton1ActionPerformed(java.awt.event.ActionEvent evt) {                                         
        float a, b, c, delta, x1, x2;

        a = Float.parseFloat(jTextField1.getText());
        b = Float.parseFloat(jTextField3.getText());
        c = Float.parseFloat(jTextField4.getText());
        
        delta = (b*b)-4*a*c;
        float raiz = (float)Math.sqrt(delta);
        x1 = (-b + raiz)/(2*a);
        x2 = (-b - raiz)/(2*a);
        
        
        jTextField6.setText(String.valueOf(delta));
        jTextField2.setText(String.valueOf(x1));
        jTextField7.setText(String.valueOf(x1));
    }                                        

